{
  "name": "realtime-ai-collab",
  "private": true,
  "scripts": {
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && lefthook install || true",
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web-client dev",
    "build": "pnpm --filter server build",
    "start": "node packages/server/dist/index.js",
    "lint": "eslint --config eslint.config.bottomlessmargaritas.js .",
    "lint:fix": "eslint --config eslint.config.bottomlessmargaritas.js . --fix",
    "format": "prettier --config prettier.config.bottomlessmargaritas.mjs --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --config prettier.config.bottomlessmargaritas.js --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "test": "pnpm --filter server test",
    "bottomlessmargaritas:format": "prettier --config prettier.config.bottomlessmargaritas.js --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "bottomlessmargaritas:format:check": "prettier --config prettier.config.bottomlessmargaritas.js --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "bottomlessmargaritas:lint": "eslint --config eslint.config.bottomlessmargaritas.js .",
    "bottomlessmargaritas:lint:fix": "eslint --config eslint.config.bottomlessmargaritas.js . --fix"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "lefthook": "^2.1.1",
    "@bottomlessmargaritas/claude-architecture-prompts": "^2.1.0",
    "@bottomlessmargaritas/formatting-configs": "^2.1.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.15.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  },
  "packageManager": "pnpm@9.15.9"
}
