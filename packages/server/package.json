    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsc-alias": "^1",
    "tsx": "^4",
