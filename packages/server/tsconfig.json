{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "app/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "*.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "vitest.config.ts",
    "vitest.integration.config.ts"
  ]
}
